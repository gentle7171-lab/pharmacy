  // ── Supabase REST helper ────────────────────────────────
  function sbFetch(path, opts) {
    var url = SUPA_URL + '/rest/v1/' + path;
    var headers = {
      'apikey': SUPA_KEY,
      'Authorization': 'Bearer ' + SUPA_KEY,
      'Content-Type': 'application/json',
      'Prefer': 'return=representation'
    };
    if (opts && opts.headers) {
      Object.assign(headers, opts.headers);
    }
    return fetch(url, Object.assign({ headers: headers }, opts || {}));
  }

  async function sbSelect(table, params, countOnly) {
    var qs = params ? '?' + params : '';
    var headers = countOnly ? { 'Prefer': 'count=exact', 'Range': '0-0' } : {};
    var res = await sbFetch(table + qs, { headers: headers });
    if (countOnly) {
      var range = res.headers.get('Content-Range');
      var total = range ? parseInt(range.split('/')[1]) : 0;
      return total;
    }
    return res.json();
  }

  async function sbInsert(table, data) {
    var res = await sbFetch(table, { method: 'POST', body: JSON.stringify(data) });
    if (!res.ok) { var e = await res.json(); return { error: e }; }
    return { data: await res.json() };
  }

  async function sbUpsert(table, data, onConflict) {
    var res = await sbFetch(table + '?on_conflict=' + onConflict, {
      method: 'POST',
      headers: { 'Prefer': 'resolution=merge-duplicates,return=representation' },
      body: JSON.stringify(data)
    });
    if (!res.ok) { var e = await res.json(); return { error: e }; }
    return { data: await res.json() };
  }

  async function sbUpdate(table, match, data) {
    var res = await sbFetch(table + '?' + match, { method: 'PATCH', body: JSON.stringify(data) });
    return res.ok;
  }

  async function sbDelete(table, match) {
    var res = await sbFetch(table + '?' + match, { method: 'DELETE' });
    return res.ok;
  }

