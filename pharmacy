    if (!Array.isArray(data) || data.length === 0) {
      errEl.textContent='員編或院區不正確'; errEl.classList.remove('hidden'); return;
    }
    var user = data[0];
    if (user.password_hash !== pwd) {
      errEl.textContent='密碼錯誤'; errEl.classList.remove('hidden'); return;
    }
    currentUser = user;
    document.getElementById('login-screen').classList.add('hidden');
    document.getElementById('app-screen').classList.remove('hidden');
    var cl = campus==='douliou'?'斗六院區':'虎尾院區';
    var bc = campus==='douliou'?'badge-dl':'badge-hw';
    document.getElementById('header-user').innerHTML = empId + ' ' + user.name + ' <span class="badge ' + bc + '">' + cl + '</span>';
    showTab('scan');
    loadCounts();
  }

  function doLogout() {
    currentUser = null;
    document.getElementById('app-screen').classList.add('hidden');
    document.getElementById('login-screen').classList.remove('hidden');
    document.getElementById('login-emp').value='';
    document.getElementById('login-pwd').value='';
  }

  // ── Tabs ──────────────────────────────────────────────────
  function showTab(tab) {
    ['scan','records','reports','admin'].forEach(function(t) {
      document.getElementById('tab-'+t).classList.add('hidden');
      document.getElementById('nav-'+t).classList.remove('active');
    });
    document.getElementById('tab-'+tab).classList.remove('hidden');
    document.getElementById('nav-'+tab).classList.add('active');
    if (tab==='records') { initRecords(); }
    if (tab==='reports') { initReports(); }
    if (tab==='admin')   { loadUsers(); loadXLSX(); }
    if (tab==='scan')    { setTimeout(function(){ document.getElementById('barcode-input').focus(); }, 100); }
  }

  // ── Scan ──────────────────────────────────────────────────
  function submitBarcode() {
    var val = document.getElementById('barcode-input').value.trim();
    if (val) processBarcode(val);
  }

  async function processBarcode(raw) {
    if (scanLocked) return;
    scanLocked = true;
    document.getElementById('barcode-input').value = '';
    document.getElementById('barcode-processing').classList.remove('hidden');
    hideScanCards();

    var parts = raw.trim().split('|');
    if (parts.length < 7) { showScanError('條碼格式不符，請確認藥袋是否正確'); scanLocked=false; return; }

    var qr = {
      patient_account: (parts[0]||'').trim(),
      patient_id:      (parts[2]||'').trim(),
      dispense_no:     (parts[3]||'').trim(),
      drug_code:       (parts[4]||'').trim(),
      quantity:        parseInt((parts[5]||'0').trim()) || 0,
      qr_unit:         (parts[6]||'').trim()
    };

    var drug = drugMap[qr.drug_code];
    if (!drug) {
      var res = await sbSelect('drugs', 'drug_code=eq.' + encodeURIComponent(qr.drug_code) + '&select=*');
      drug = Array.isArray(res) && res.length > 0 ? res[0] : null;
    }
    if (!drug) { showScanError('找不到藥品台大碼 ' + qr.drug_code); scanLocked=false; return; }

    document.getElementById('barcode-processing').classList.add('hidden');
    pendingQR = qr; pendingDrug = drug;
    showConfirm(qr, drug);
    scanLocked = false;
  }

  function showConfirm(qr, drug) {
    document.getElementById('ci-account').textContent  = qr.patient_account;
    document.getElementById('ci-pid').textContent      = qr.patient_id;
    document.getElementById('ci-dispno').textContent   = qr.dispense_no;
    document.getElementById('ci-drugcode').textContent = drug.drug_code;
    document.getElementById('ci-stockcode').textContent= drug.stock_code;
    document.getElementById('ci-name').textContent     = drug.name;
    document.getElementById('ci-qty').textContent      = qr.quantity + ' ' + drug.unit;
    var cl = drug.ctrl_level;
    document.getElementById('ci-ctrl').innerHTML =
      (cl==='0'||cl==='4') ? '<span class="badge badge-gen">一般</span>'
      : (cl==='1'||cl==='2') ? '<span class="badge badge-c12">管'+cl+'級</span>'
      : '<span class="badge badge-c3">管'+cl+'級</span>';

    var prefix = qr.dispense_no.toUpperCase()[0];
    var isEmg  = prefix === 'E';
    var pc = prefix==='A' ? 'douliou' : prefix==='D' ? 'huwei'
           : (currentUser.campus==='douliou' ? 'huwei' : 'douliou');

    document.getElementById('prescribe-sel').value = pc;
    document.getElementById('dispense-sel').value  = currentUser.campus;
    document.getElementById('dispense-fixed').textContent = currentUser.campus==='douliou'?'斗六院區':'虎尾院區';

    var pBox=document.getElementById('prescribe-box'), dBox=document.getElementById('dispense-box');
    var pLbl=document.getElementById('prescribe-label'), dLbl=document.getElementById('dispense-label');
    var dFix=document.getElementById('dispense-fixed'),  dSel=document.getElementById('dispense-sel');
    var badge=document.getElementById('confirm-badge'),  emg=document.getElementById('emergency-alert');

    if (isEmg) {
      emg.classList.remove('hidden');
      badge.className='badge badge-emg'; badge.textContent='急診處方';
      pBox.classList.add('emergency'); dBox.classList.add('emergency');
      pLbl.className='campus-box-label emg'; pLbl.textContent='開方院區（請選）';
      dLbl.className='campus-box-label emg'; dLbl.textContent='領藥院區（請選）';
      dFix.classList.add('hidden'); dSel.classList.remove('hidden');
    } else {
      emg.classList.add('hidden');
      badge.className='badge badge-pend'; badge.textContent='待確認';
      pBox.classList.remove('emergency'); dBox.classList.remove('emergency');
      pLbl.className='campus-box-label'; pLbl.textContent='開方院區（自動）';
      dLbl.className='campus-box-label'; dLbl.textContent='領藥院區（自動）';
      dFix.classList.remove('hidden'); dSel.classList.add('hidden');
    }
    document.getElementById('scan-confirm-card').classList.remove('hidden');
  }

  async function doConfirm() {
    var btn = document.getElementById('confirm-btn');
    btn.disabled=true; btn.textContent='儲存中...';
    var isEmg = !document.getElementById('dispense-sel').classList.contains('hidden');
    var dispCampus = isEmg ? document.getElementById('dispense-sel').value : currentUser.campus;
    var result = await sbInsert('dispensing_records', {
      patient_account:  pendingQR.patient_account,
      patient_id:       pendingQR.patient_id,
      dispense_no:      pendingQR.dispense_no,
      drug_code:        pendingQR.drug_code,
      quantity:         pendingQR.quantity,
      qr_unit:          pendingQR.qr_unit,
      stock_code:       pendingDrug.stock_code,
      drug_name:        pendingDrug.name,
      ctrl_level:       pendingDrug.ctrl_level,
      drug_unit:        pendingDrug.unit,
      prescribe_campus: document.getElementById('prescribe-sel').value,
      dispense_campus:  dispCampus,
      pharmacist_emp_id:currentUser.emp_id
    });
    btn.disabled=false; btn.textContent='確認';
    if (result.error) { showScanError('儲存失敗：' + JSON.stringify(result.error)); return; }
    hideScanCards();
    document.getElementById('success-drug-info').textContent = pendingDrug.drug_code + ' · ' + pendingDrug.name;
    document.getElementById('scan-success-toast').classList.remove('hidden');
    loadCounts();
    setTimeout(function() {
      document.getElementById('scan-success-toast').classList.add('hidden');
      document.getElementById('barcode-input').focus();
    }, 800);
  }

  function hideScanCards() {
    ['scan-idle-card','scan-confirm-card','scan-error-card'].forEach(function(id){
      document.getElementById(id).classList.add('hidden');
    });
    document.getElementById('scan-idle-card').classList.remove('hidden');
    document.getElementById('scan-success-toast').classList.add('hidden');
    document.getElementById('barcode-processing').classList.add('hidden');
  }

  function showScanError(msg) {
    document.getElementById('scan-idle-card').classList.add('hidden');
    document.getElementById('error-msg').textContent = msg;
    document.getElementById('scan-error-card').classList.remove('hidden');
  }

  function resetScan() {
    hideScanCards();
    pendingQR=null; pendingDrug=null;
    document.getElementById('barcode-input').focus();
  }

  // ── Counts ────────────────────────────────────────────────
  async function loadCounts() {
    var today = new Date().toISOString().slice(0,10);
    var d = new Date(); var day=d.getDay()||7; d.setDate(d.getDate()-day+1);
    var weekStart = d.toISOString().slice(0,10);
    var tc = await sbSelect('dispensing_records',
      'dispensed_at=gte.' + today + 'T00:00:00&dispensed_at=lte.' + today + 'T23:59:59&select=id', true);
    var wc = await sbSelect('dispensing_records',
      'dispensed_at=gte.' + weekStart + 'T00:00:00&select=id', true);
    document.getElementById('cnt-today').textContent = tc;
    document.getElementById('cnt-week').textContent  = wc;
  }

  // ── Records ───────────────────────────────────────────────
  function initRecords() {
    if (!document.getElementById('rec-date').value)
      document.getElementById('rec-date').value = new Date().toISOString().slice(0,10);
  }

  async function loadRecords() {
    var date  = document.getElementById('rec-date').value;
    var type  = document.getElementById('rec-type').value;
    var tbody = document.getElementById('records-tbody');
    tbody.innerHTML = '<tr><td colspan="11" style="text-align:center;padding:20px;color:#9ca3af;">載入中...</td></tr>';
    var qs = 'dispensed_at=gte.' + date + 'T00:00:00&dispensed_at=lte.' + date + 'T23:59:59&order=dispensed_at.desc&select=*';
    if (type==='general') qs += '&ctrl_level=in.(0,4)';
    else if (type==='ctrl12') qs += '&ctrl_level=in.(1,2)';
    else if (type==='ctrl3')  qs += '&ctrl_level=eq.3';
    var data = await sbSelect('dispensing_records', qs);
    if (!Array.isArray(data) || data.length===0) {
      tbody.innerHTML='<tr><td colspan="11" style="text-align:center;padding:20px;color:#9ca3af;">查無資料</td></tr>';
      document.getElementById('rec-count').textContent='共 0 筆'; return;
    }
    document.getElementById('rec-count').textContent='共 '+data.length+' 筆';
    tbody.innerHTML = data.map(function(r) {
      var t = new Date(r.dispensed_at).toLocaleTimeString('zh-TW',{hour:'2-digit',minute:'2-digit'});
      var cl = r.ctrl_level;
      var ctrlB = (cl==='0'||cl==='4') ? '<span class="badge badge-gen">一般</span>'
        : (cl==='1'||cl==='2') ? '<span class="badge badge-c12">管'+cl+'</span>'
        : '<span class="badge badge-c3">管'+cl+'</span>';
      var pB='<span class="badge badge-'+(r.prescribe_campus==='douliou'?'dl':'hw')+'">'+(r.prescribe_campus==='douliou'?'斗六':'虎尾')+'</span>';
      var dB='<span class="badge badge-'+(r.dispense_campus==='douliou'?'dl':'hw')+'">'+(r.dispense_campus==='douliou'?'斗六':'虎尾')+'</span>';
      return '<tr><td class="mono">'+t+'</td><td class="mono">'+(r.patient_id||'')+'</td>'
        +'<td class="mono">'+(r.dispense_no||'')+'</td><td class="mono">'+(r.drug_code||'')+'</td>'
        +'<td class="mono">'+(r.stock_code||'')+'</td>'
        +'<td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="'+(r.drug_name||'')+'">'+(r.drug_name||'')+'</td>'
        +'<td style="text-align:right;">'+(r.quantity||'')+'</td><td>'+(r.drug_unit||'')+'</td>'
        +'<td>'+ctrlB+'</td><td>'+pB+'</td><td>'+dB+'</td></tr>';
    }).join('');
  }

  // ── Reports ───────────────────────────────────────────────
  function initReports() {
    if (!document.getElementById('rpt-date').value)
      document.getElementById('rpt-date').value = new Date().toISOString().slice(0,10);
  }

  var CL = {douliou:'斗六院區', huwei:'虎尾院區'};

  async function fetchRptData(type, date, isWeekly) {
    var sd=date, ed=date;
    if (isWeekly) {
      var d=new Date(date), day=d.getDay()||7;
      var mon=new Date(d); mon.setDate(d.getDate()-day+1);
      var sun=new Date(mon); sun.setDate(mon.getDate()+6);
      sd=mon.toISOString().slice(0,10); ed=sun.toISOString().slice(0,10);
    }
    var qs='dispensed_at=gte.'+sd+'T00:00:00&dispensed_at=lte.'+ed+'T23:59:59&order=dispensed_at.asc&select=*';
    if (type==='general') qs+='&ctrl_level=in.(0,4)';
    else if (type==='ctrl12') qs+='&ctrl_level=in.(1,2)';
    else if (type==='ctrl3')  qs+='&ctrl_level=eq.3';
    return await sbSelect('dispensing_records', qs);
  }

  async function exportGeneral() {
    var date=document.getElementById('rpt-date').value;
    var isW=document.getElementById('rpt-general-type').value==='weekly';
    var rows=await fetchRptData('general',date,isW);
    if (!rows||!rows.length){alert('查無資料');return;}
    var detail=[['日期時間','病患帳號','病歷號','領藥號','藥品台大碼','庫存碼','商品名','數量','單位','開方院區','領藥院區','操作藥師']];
    rows.forEach(function(r){detail.push([new Date(r.dispensed_at).toLocaleString('zh-TW'),r.patient_account,r.patient_id,r.dispense_no,r.drug_code,r.stock_code,r.drug_name,r.quantity,r.drug_unit,CL[r.prescribe_campus],CL[r.dispense_campus],r.pharmacist_emp_id]);});
    var netMap={};
    rows.forEach(function(r){
      if(!netMap[r.drug_code]) netMap[r.drug_code]={dc:r.drug_code,sc:r.stock_code,nm:r.drug_name,un:r.drug_unit,dl:0,hw:0};
      if(r.prescribe_campus==='douliou'&&r.dispense_campus==='huwei') netMap[r.drug_code].dl+=r.quantity;
      else if(r.prescribe_campus==='huwei'&&r.dispense_campus==='douliou') netMap[r.drug_code].hw+=r.quantity;
    });
    var net=[['藥品台大碼','庫存碼','商品名','單位','斗六→虎尾(顆)','虎尾→斗六(顆)','淨額方向','淨額數量']];
    Object.values(netMap).forEach(function(i){var n=i.dl-i.hw;net.push([i.dc,i.sc,i.nm,i.un,i.dl,i.hw,n>0?'斗六→虎尾':n<0?'虎尾→斗六':'持平',Math.abs(n)]);});
    var wb=XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(detail),'明細');
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(net),'淨額統計');
    XLSX.writeFile(wb,'一般藥品互領'+(isW?'週':'日')+'報表_'+date+'.xlsx');
  }

  async function exportCtrl12() {
    var date=document.getElementById('rpt-date').value;
    var rows=await fetchRptData('ctrl12',date,false);
    if(!rows||!rows.length){alert('查無資料');return;}
    exportCtrlSheet(rows,'管一二級藥品互領日報表_'+date+'.xlsx');
  }

  async function exportCtrl3() {
    var date=document.getElementById('rpt-date').value;
    var rows=await fetchRptData('ctrl3',date,false);
    if(!rows||!rows.length){alert('查無資料');return;}
    exportCtrlSheet(rows,'管三級藥品互領日報表_'+date+'.xlsx');
  }

  function exportCtrlSheet(rows, fname) {
    var ws=[['日期時間','病患帳號','病歷號','領藥號','藥品台大碼','庫存碼','商品名','管制級別','數量','單位','開方院區','領藥院區','操作藥師','核對']];
    rows.forEach(function(r){ws.push([new Date(r.dispensed_at).toLocaleString('zh-TW'),r.patient_account,r.patient_id,r.dispense_no,r.drug_code,r.stock_code,r.drug_name,'管'+r.ctrl_level,r.quantity,r.drug_unit,CL[r.prescribe_campus],CL[r.dispense_campus],r.pharmacist_emp_id,'']);});
    var wb=XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(ws),'明細');
    XLSX.writeFile(wb,fname);
  }

  // ── Admin ─────────────────────────────────────────────────
  async function loadUsers() {
    var data=await sbSelect('users','order=campus.asc,emp_id.asc&select=*');
    var el=document.getElementById('user-list');
    if(!Array.isArray(data)||!data.length){el.innerHTML='<div style="font-size:12px;color:#9ca3af;">尚無帳號</div>';return;}
    el.innerHTML=data.map(function(u){
      var cl=u.campus==='douliou'?'dl':'hw', lb=u.campus==='douliou'?'斗六':'虎尾';
      return '<div class="user-row"><div><span class="badge badge-'+cl+'" style="margin-right:6px;">'+lb+'</span>'+u.emp_id+' '+u.name+'</div>'
        +'<div style="display:flex;gap:6px;">'
        +'<button class="btn" style="font-size:11px;padding:3px 8px;" onclick="window._resetPwd(''+u.id+'',''+u.emp_id+'')">重設密碼</button>'
        +'<button class="btn" style="font-size:11px;padding:3px 8px;color:#dc2626;border-color:#fca5a5;" onclick="window._delUser(''+u.id+'',''+u.name+'')">刪除</button>'
        +'</div></div>';
    }).join('');
  }

  window._resetPwd = async function(id, empId) {
    if(!confirm('確定要將 '+empId+' 的密碼重設為員編嗎？')) return;
    await sbUpdate('users','id=eq.'+id,{password_hash:empId});
    alert('密碼已重設');
  };

  window._delUser = async function(id, name) {
    if(!confirm('確定要刪除 '+name+' 嗎？')) return;
    await sbDelete('users','id=eq.'+id);
    loadUsers();
  };

  async function addUser() {
    var empId=document.getElementById('new-emp').value.trim();
    var name=document.getElementById('new-name').value.trim();
    var campus=document.getElementById('new-campus').value;
    if(!empId||!name){alert('請填寫員編和姓名');return;}
    var r=await sbInsert('users',{emp_id:empId,name:name,campus:campus,password_hash:empId,is_active:true});
    if(r.error){alert('新增失敗：'+JSON.stringify(r.error));return;}
    document.getElementById('new-emp').value='';
    document.getElementById('new-name').value='';
    alert('已新增 '+name+'，預設密碼為員編 '+empId);
    loadUsers();
  }

  // ── Drug import ───────────────────────────────────────────
  function loadXLSX() {
    if (window.XLSX) return;
    var s=document.createElement('script');
    s.src='https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js';
    document.head.appendChild(s);
  }

  async function importDrugs() {
    var file=document.getElementById('drug-file').files[0];
    if(!file){alert('請選擇 Excel 檔案');return;}
    var statusEl=document.getElementById('import-status');
    statusEl.textContent='讀取中...'; statusEl.style.color='#185FA5';
    var reader=new FileReader();
    reader.onload=async function(e){
      var wb=XLSX.read(e.target.result,{type:'array'});
      var ws=wb.Sheets[wb.SheetNames[0]];
      var rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
      var hi=-1;
      for(var i=0;i<rows.length;i++){if(rows[i].indexOf('庫存碼')>=0){hi=i;break;}}
      if(hi===-1){statusEl.textContent='找不到標題行';statusEl.style.color='#dc2626';return;}
      var h=rows[hi];
      var iS=h.indexOf('庫存碼'),iD=h.indexOf('藥品台大碼'),iN=h.indexOf('商品名'),iC=h.indexOf('管制藥級別'),iU=h.indexOf('計價單位');
      var drugs=[];
      for(var j=hi+1;j<rows.length;j++){
        var r=rows[j];
        var sc=String(r[iS]||'').trim(),dc=String(r[iD]||'').trim();
        if(!sc||!dc||sc==='庫存碼') continue;
        drugs.push({stock_code:sc,drug_code:dc,name:String(r[iN]||'').trim().replace(/^=?"?|"?$/g,''),ctrl_level:String(r[iC]||'0').trim(),unit:String(r[iU]||'').trim()});
      }
      statusEl.textContent='匯入 '+drugs.length+' 筆中...';
      var done=0, bs=200;
      for(var k=0;k<drugs.length;k+=bs){
        await sbUpsert('drugs',drugs.slice(k,k+bs),'drug_code');
        done+=Math.min(bs,drugs.length-k);
        statusEl.textContent='匯入中... '+done+'/'+drugs.length;
      }
      statusEl.textContent='✅ 匯入完成！共 '+done+' 筆';
      statusEl.style.color='#059669';
    };
    reader.readAsArrayBuffer(file);
  }

  // ── Load XLSX for reports ─────────────────────────────────
  var xlsxScript=document.createElement('script');
  xlsxScript.src='https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js';
  document.head.appendChild(xlsxScript);

})();
</script>
